{
    "name": "kissous/uuid7",
    "description": "Lightweight, dependency-free PHP library to generate and handle time-ordered identifiers: UUIDv7 (RFC 9562) and ULID.",
    "type": "library",
    "license": "MIT",
    "keywords": ["uuid", "uuidv7", "uuid7", "ulid", "rfc9562", "identifier", "time-ordered", "guid"],
    "homepage": "https://github.com/Kissous/uuid7",
    "support": {
        "issues": "https://github.com/Kissous/uuid7/issues",
        "source": "https://github.com/Kissous/uuid7"
    },
    "authors": [
        {
            "name": "Omar Kissous",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.64",
        "ramsey/uuid": "^4.7"
    },
    "autoload": {
        "psr-4": {
            "Kissous\\Uuid7\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kissous\\Uuid7\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --exclude-testsuite=Benchmark",
        "test:coverage": "phpunit --exclude-testsuite=Benchmark --coverage-html build/coverage --coverage-text",
        "stan": "phpstan analyse",
        "cs": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "bench": "phpunit --testsuite=Benchmark"
    },
    "scripts-descriptions": {
        "test": "Run the PHPUnit test suite (Unit + Property)",
        "test:coverage": "Run tests with a coverage report (requires Xdebug or PCOV)",
        "stan": "PHPStan static analysis (max level)",
        "cs": "Fix code style with PHP-CS-Fixer",
        "cs:check": "Check code style without changing files (dry-run)",
        "bench": "Run benchmarks against ramsey/uuid"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
